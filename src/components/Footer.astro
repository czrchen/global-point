---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-text">gpf</span>
        <span class="brand-tag">Brings Fun to Life</span>
      </a>
      <p>Global Point Foods — a Malaysian soft-candy maker spreading fun, one flavour at a time. A Wah Kong Corporation company.</p>
      <div class="socials">
        <a href="#" aria-label="Facebook">Facebook</a>
        <a href="#" aria-label="Instagram">Instagram</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <a href="/products">Products</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Flavours</h4>
      <a href="/products">Fruities</a>
      <a href="/products">Mint &amp; Cooling</a>
      <a href="/products">Tropical Series</a>
      <a href="/products">OEM &amp; Private Label</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <p class="muted">Sales Office: No. 6, Jalan Pahat 16/8A, Section 16, 40200 Shah Alam, Selangor</p>
      <a href="tel:+60355183360">+603-5518 3360</a>
      <a href="mailto:inquiry@globalpoint.com.my">inquiry@globalpoint.com.my</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} Global Point Foods Industries Sdn Bhd · A Wah Kong Corporation company</span>
    <span>Shah Alam &amp; Lunas, Malaysia</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--ink);
    color: #C7C9E0;
    margin-top: 110px;
    padding: 70px 0 30px;
  }
  .footer-inner { display: grid; grid-template-columns: 1.7fr 1fr 1fr 1.4fr; gap: 40px; }
  .brand { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; }
  .brand-text { font-family: var(--font-display); font-weight: 800; font-size: 1.7rem; color: #fff; letter-spacing: -0.03em; }
  .brand-tag { font-family: var(--font-display); font-weight: 600; font-size: .8rem; color: var(--gold); }
  .footer-brand p { color: #9396BC; max-width: 330px; font-size: .95rem; line-height: 1.6; }

  .socials { display: flex; gap: 18px; margin-top: 22px; }
  .socials a { font-size: .88rem; font-weight: 500; color: #9396BC; transition: color .2s ease; }
  .socials a:hover { color: var(--gold); }

  .footer-col h4 {
    font-family: var(--font-display); font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 18px; color: #6E72A0;
  }
  .footer-col a { display: block; color: #C7C9E0; padding: 6px 0; font-size: .95rem; transition: color .18s ease; }
  .footer-col a:hover { color: #fff; }
  .footer-col .muted { color: #9396BC; margin-bottom: 14px; font-size: .95rem; line-height: 1.6; }

  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    margin-top: 54px; padding-top: 26px;
    border-top: 1px solid rgba(255,255,255,.08);
    color: #6E72A0; font-size: .86rem;
  }

  @media (max-width: 860px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .footer-inner { grid-template-columns: 1fr; gap: 30px; } }
</style>
